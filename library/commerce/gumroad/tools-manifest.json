{
  "api_name": "gumroad",
  "base_url": "https://api.gumroad.com/v2",
  "description": "Gumroad OAuth 2.0 API for products, sales, subscribers, licenses, payouts, tax data, and resource subscriptions.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "bearer_token",
    "header": "Authorization",
    "env_vars": [
      "GUMROAD_ACCESS_TOKEN"
    ],
    "env_var_specs": [
      {
        "name": "GUMROAD_ACCESS_TOKEN",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "earnings_get",
      "description": "Retrieve an annual earnings breakdown for the authenticated user. Requires view_tax_data scope. Required: year. Returns the SuccessEnvelope.",
      "method": "GET",
      "path": "/earnings",
      "params": [
        {
          "name": "year",
          "type": "int",
          "location": "query",
          "description": "Four-digit tax year.",
          "required": true
        }
      ]
    },
    {
      "name": "files_abort",
      "description": "Cancel a multipart upload started by /files/presign. Requires edit_products scope. Required: key, upload_id. Returns the new SuccessEnvelope.",
      "method": "POST",
      "path": "/files/abort",
      "params": [
        {
          "name": "key",
          "type": "string",
          "location": "body",
          "description": "Key",
          "required": true
        },
        {
          "name": "upload_id",
          "type": "string",
          "location": "body",
          "description": "Upload id",
          "required": true
        }
      ]
    },
    {
      "name": "files_complete",
      "description": "Finalize a multipart upload started by /files/presign. Requires edit_products scope. Required: key, parts, upload_id. Returns the new SuccessEnvelope.",
      "method": "POST",
      "path": "/files/complete",
      "params": [
        {
          "name": "key",
          "type": "string",
          "location": "body",
          "description": "Key",
          "required": true
        },
        {
          "name": "parts",
          "type": "array",
          "location": "body",
          "description": "Parts",
          "required": true
        },
        {
          "name": "upload_id",
          "type": "string",
          "location": "body",
          "description": "Upload id",
          "required": true
        }
      ]
    },
    {
      "name": "files_presign",
      "description": "Start a multipart upload and return presigned URLs for each part. Requires edit_products scope. Required: file_size, filename. Returns the new SuccessEnvelope.",
      "method": "POST",
      "path": "/files/presign",
      "params": [
        {
          "name": "file_size",
          "type": "int",
          "location": "body",
          "description": "File size in bytes, max 20 GB.",
          "required": true
