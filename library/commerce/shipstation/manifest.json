{
  "manifest_version": "0.3",
  "name": "shipstation-pp-mcp",
  "display_name": "Shipstation",
  "version": "4.2.2",
  "description": "Shipstation API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/shipstation-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/shipstation-pp-mcp",
      "args": [],
      "env": {
        "SHIPSTATION_API_KEY": "${user_config.shipstation_api_key}"
      }
    }
  },
  "user_config": {
    "shipstation_api_key": {
      "type": "string",
      "title": "SHIPSTATION_API_KEY",
      "description": "Sets SHIPSTATION_API_KEY for the Shipstation MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
