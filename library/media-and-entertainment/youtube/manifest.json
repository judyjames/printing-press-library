{
  "manifest_version": "0.3",
  "name": "youtube-pp-mcp",
  "display_name": "Youtube Data",
  "version": "4.2.2",
  "description": "Youtube Data API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/youtube-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/youtube-pp-mcp",
      "args": [],
      "env": {
        "YOUTUBE_API_KEY": "${user_config.youtube_api_key}"
      }
    }
  },
  "user_config": {
    "youtube_api_key": {
      "type": "string",
      "title": "YOUTUBE_API_KEY",
      "description": "YouTube Data API key for read-only public-data operations",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
