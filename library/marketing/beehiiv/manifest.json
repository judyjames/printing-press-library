{
  "manifest_version": "0.3",
  "name": "beehiiv-pp-mcp",
  "display_name": "Beehiiv",
  "version": "4.2.2",
  "description": "Beehiiv API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/beehiiv-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/beehiiv-pp-mcp",
      "args": [],
      "env": {
        "BEEHIIV_BEARER_AUTH": "${user_config.beehiiv_bearer_auth}"
      }
    }
  },
  "user_config": {
    "beehiiv_bearer_auth": {
      "type": "string",
      "title": "BEEHIIV_BEARER_AUTH",
      "description": "Sets BEEHIIV_BEARER_AUTH for the Beehiiv MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
